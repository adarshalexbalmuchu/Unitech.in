# ─────────────────────────────────────────────────────────────────────────────
# .env.shiprocket.example
# ShipRocket integration environment variables for Supabase Edge Functions
# Copy to .env and fill in actual values before deployment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (usually auto-set, but document for clarity) ───────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ── ShipRocket API ──────────────────────────────────────────────────────────
SHIPROCKET_API_BASE=https://apiv2.shiprocket.in/v1/external
SHIPROCKET_EMAIL=your-shiprocket-email@example.com
SHIPROCKET_PASSWORD=your-shiprocket-password

# ── Webhook HMAC signature verification ─────────────────────────────────────
SHIPROCKET_WEBHOOK_SECRET=your-webhook-hmac-secret

# ── Cron / Scheduled function auth ──────────────────────────────────────────
# Used by pg_cron to invoke redact-shiprocket-pii without a JWT.
# Generate with: openssl rand -hex 32
CRON_SECRET=generate-a-random-64-char-hex-string

# ── pg_cron integration (Supabase app.settings for SQL) ─────────────────────
# These are set via Supabase Dashboard → Settings → Database → App Settings
# or via ALTER DATABASE ... SET app.settings.supabase_url = '...';
#
# app.settings.supabase_url   = (same as SUPABASE_URL above)
# app.settings.cron_secret    = (same as CRON_SECRET above)
