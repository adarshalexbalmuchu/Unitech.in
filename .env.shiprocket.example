# ============================================================
# ShipRocket Integration — Environment Variables
# ============================================================
#
# HOW TO USE
# ──────────
# Copy this file, fill in your values, and set the variables
# as Supabase Edge Function secrets:
#
#   supabase secrets set SHIPROCKET_API_BASE=... \
#                        SHIPROCKET_EMAIL=... \
#                        SHIPROCKET_PASSWORD=... \
#                        ...
#
# Never commit real credentials. This file is tracked in git
# as a template only.
#
# ============================================================


# SHIPROCKET_API_BASE
# ───────────────────
# Swap this single variable to switch between sandbox and production.
# Nothing else in the codebase changes between environments.
#
# Sandbox  (use during development and testing):
#   https://apiv2.shiprocket.in/v1/external   ← same host, sandbox is
#   controlled by using test credentials in your ShipRocket dashboard
#
# Production:
#   https://apiv2.shiprocket.in/v1/external
#
SHIPROCKET_API_BASE=https://apiv2.shiprocket.in/v1/external

# ShipRocket account credentials used by the token manager.
# These correspond to the email/password you use to log in to
# the ShipRocket dashboard. The token manager exchanges them for
# a JWT that is cached and refreshed automatically.
SHIPROCKET_EMAIL=your-shiprocket-email@example.com
SHIPROCKET_PASSWORD=your-shiprocket-password

# SHIPROCKET_CHANNEL_SECRET
# ─────────────────────────
# The secret ShipRocket sends in the X-Shiprocket-Hmac header on
# every webhook POST. The shiprocket-webhook Edge Function verifies
# incoming requests against this value — reject anything that does
# not match.
# Find this in: ShipRocket dashboard → Settings → API → Webhooks
SHIPROCKET_CHANNEL_SECRET=your-webhook-channel-secret

# SHIPROCKET_WAREHOUSE_PINCODE
# ────────────────────────────
# The pincode of your warehouse / pickup location.
# Stored as origin_pincode on every shipment row at creation time.
# Used for zone calculation (origin + destination pincode pair
# determines local / regional / metro / national billing zone).
SHIPROCKET_WAREHOUSE_PINCODE=your-warehouse-pincode

# SHIPROCKET_PICKUP_LOCATION_NAME
# ────────────────────────────────
# The name of the pickup location as configured in your ShipRocket
# dashboard (Settings → Manage Pickups). Must match exactly — this
# value is sent in the create-order API call.
SHIPROCKET_PICKUP_LOCATION_NAME=your-pickup-location-name
